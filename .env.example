# Core ports
PORT=1930
DASHBOARD_PORT=1931

# API key (clients send as Authorization: Bearer <key>)
API_KEY=pool-proxy-secret-key

# Database (SQLite)
DATABASE_PATH=./data/poolprox3.db

# Token encryption key (32 hex chars). install.sh / install.ps1 generate one for you.
ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6

# Auth bot (Python + Playwright/Camoufox).
# Defaults below assume the in-tree venv at scripts/auth/.venv created by the installer.
AUTH_SCRIPT_PATH=./scripts/auth/login.py
# Python path — leave empty for auto-detection (recommended).
# The server auto-detects the correct venv path for your OS:
#   Linux/macOS: scripts/auth/.venv/bin/python
#   Windows:     scripts/auth/.venv/Scripts/python.exe
PYTHON_PATH=
AUTH_SCRIPT_CWD=./scripts/auth

# Outbound proxy for the auth bot (optional, e.g. http://user:pass@host:port)
PROXY_URL=

# Browser engine for auth: camoufox (anti-detect, default) | chromium
BROWSER_ENGINE=camoufox
HEADLESS=true

# Captcha solver (optional)
CAPTCHA_SERVICE=none
CAPTCHA_API_KEY=

# Kiro Pro auto-upgrade (uses VCC pool)
KIRO_PRO_UPGRADE=false

# ─── Relay Proxy ───────────────────────────────────────────────────────────
# Expose your pool to the internet via WebSocket tunneling (like 9router relay).
#
# Modes:
#   disabled - relay off (default)
#   client   - connect to a remote relay server, expose this pool
#   server   - accept tunnel connections from remote pools
#   both     - run both client and server simultaneously
RELAY_MODE=disabled

# Client mode: URL of the relay server to connect to
RELAY_SERVER_URL=

# Shared secret for tunnel authentication (both client and server must match)
RELAY_SECRET=

# Human-readable name for this pool instance (shown on relay server dashboard)
RELAY_PEER_NAME=

# Server mode: public base URL for generating tunnel URLs
# e.g. https://relay.example.com → tunnels get https://relay.example.com/relay/{id}/v1
RELAY_PUBLIC_BASE_URL=

# Server mode: max concurrent tunnel connections (default: 50)
RELAY_MAX_TUNNELS=50

# Auto-start relay on server boot (default: false)
RELAY_AUTO_START=false
